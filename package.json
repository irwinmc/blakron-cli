{
	"name": "@blakron/cli",
	"version": "0.2.0",
	"description": "Blakron CLI - build tool for Blakron game engine",
	"type": "module",
	"bin": {
		"blakron": "./dist/index.js"
	},
	"main": "./dist/define.js",
	"types": "./dist/define.d.ts",
	"scripts": {
		"build": "tsc --build",
		"dev": "tsc --watch",
		"clean": "rm -rf dist",
		"test": "vitest run",
		"test:watch": "vitest",
		"blakron": "tsx src/index.ts"
	},
	"dependencies": {
		"commander": "^13.0.0",
		"esbuild": "^0.25.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.6.0",
		"vitest": "^4.1.4"
	},
	"packageManager": "pnpm@10.33.0"
}
